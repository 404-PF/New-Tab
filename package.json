{
  "name": "new-tab",
  "version": "0.4.4",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "description": "Chrome/Edge new tab extension",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/ background/tools/",
    "lint:fix": "eslint src/ tests/ background/tools/ --fix",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "src/**/*.js": "eslint --fix",
    "tests/**/*.js": "eslint --fix",
    "background/tools/**/*.js": "eslint --fix",
    "*.{js,mjs}": "eslint --fix"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^16.4.0",
    "vitest": "^3.0.0"
  }
}
